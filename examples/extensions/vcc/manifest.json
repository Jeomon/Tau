{
  "tau": {
    "name": "VCC",
    "author": "jeomon",
    "settings": {
      "title": "VCC (algorithmic compaction)",
      "fields": [
        {
          "key": "override_default_compaction",
          "label": "Handle all compaction",
          "type": "bool",
          "default": false,
          "description": "When on, vcc replaces tau's LLM summarizer for every compaction (/compact, auto-threshold, overflow). When off, vcc only runs for /vcc."
        },
        {
          "key": "debug",
          "label": "Debug",
          "type": "bool",
          "default": false,
          "description": "Write per-compaction diagnostics to /tmp/vcc-debug.json."
        }
      ]
    }
  }
}
