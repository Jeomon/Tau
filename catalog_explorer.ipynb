            "source": [
                "from tau.inference.model import catalog as cmod\n",
                "\n",
                "def tau_ids_for(dev_id):\n",
                "    out = []\n",
                "    for label, pmap in [(\"text\", cmod.PROVIDER_MAP), (\"image\", cmod.IMAGE_PROVIDER_MAP),\n",
                "                        (\"video\", cmod.VIDEO_PROVIDER_MAP), (\"audio\", cmod.AUDIO_PROVIDER_MAP)]:\n",
                "        for tau_id, spec in pmap.items():\n",
                "            dev = spec if isinstance(spec, str) else getattr(spec, \"dev_id\", str(spec))\n",
                "            if dev == dev_id:\n",
                "                out.append(f\"{tau_id}({label})\")\n",
                "    return \", \".join(sorted(set(out))) or \"-\"\n",
                "\n",
                "print(f\"{'models.dev id':22} {'models':>7}   tau mapping\")\n",
                "print(\"-\" * 78)\n",
                "for dev_id, p in sorted(data.items(), key=lambda kv: -len(kv[1].get(\"models\", {}))):\n",
                "    print(f\"{dev_id:22} {len(p.get('models', {})):>7}   {tau_ids_for(dev_id)}\")"
            ]
        },
