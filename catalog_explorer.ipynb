            "source": [
                "def classify(m):\n",
                "    mods = m.get(\"modalities\") or {}\n",
                "    i, o = set(mods.get(\"input\") or []), set(mods.get(\"output\") or [\"text\"])\n",
                "    if \"image\" in o: return \"image-gen\"\n",
                "    if \"video\" in o: return \"video-gen\"\n",
                "    if o == {\"audio\"}: return \"tts\"\n",
                "    if o == {\"text\"} and i == {\"audio\"}: return \"stt\"\n",
                "    if \"audio\" in o: return \"realtime\"\n",
                "    return \"chat\"\n",
                "\n",
                "groups = {}\n",
                "for pid, p in data.items():\n",
                "    for m in p.get(\"models\", {}).values():\n",
                "        if isinstance(m, dict):\n",
                "            groups.setdefault(classify(m), []).append((pid, m))\n",
                "\n",
                "for kind, items in sorted(groups.items(), key=lambda kv: -len(kv[1])):\n",
                "    providers = Counter(pid for pid, _ in items)\n",
                "    top = \", \".join(f\"{k}:{v}\" for k, v in providers.most_common(5))\n",
                "    print(f\"{kind:10} {len(items):>4}   {top}\")"
            ]
        },
