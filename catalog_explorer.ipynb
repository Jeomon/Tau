                "def effort_values(m):\n",
                "    for o in m.get(\"reasoning_options\") or []:\n",
                "        if o.get(\"type\") == \"effort\":\n",
                "            return o.get(\"values\") or []\n",
                "    return None\n",
                "\n",
                "print(f\"{'model':34} {'suppress_sampling':>18} {'adaptive':>9} {'uses_level':>11}\")\n",
                "print(\"-\" * 78)\n",
                "for pid, tau_pid in [(\"anthropic\", \"anthropic\"), (\"google\", \"google\")]:\n",
                "    for mid, m in sorted(data[pid][\"models\"].items()):\n",
                "        if not isinstance(m, dict) or classify(m) != \"chat\":\n",
                "            continue\n",
                "        ev = effort_values(m)\n",
                "        suppress = m.get(\"temperature\") is False\n",
                "        adaptive = tau_pid == \"anthropic\" and ev is not None and \"max\" in ev\n",
                "        uses_level = tau_pid == \"google\" and ev is not None\n",
                "        print(f\"{mid:34} {str(suppress):>18} {str(adaptive):>9} {str(uses_level):>11}\")"
            ]
