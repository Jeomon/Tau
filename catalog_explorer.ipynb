            "source": [
                "from tau.inference.provider.registry import ProviderRegistry\n",
                "from tau.inference.provider.types import APIProvider\n",
                "from tau.auth.manager import AuthManager\n",
                "\n",
                "registry = ProviderRegistry.from_builtins()\n",
                "auth = AuthManager.create(registry)\n",
                "\n",
                "def describe(modality, providers):\n",
                "    print(f\"## {modality} ({len(providers)})\")\n",
                "    print(f\"{'id':14} {'auth_type':9} {'configured':>10} {'source':>8}   base_url\")\n",
                "    print(\"-\" * 90)\n",
                "    for p in sorted(providers, key=lambda p: p.id):\n",
                "        status = auth.get_auth_status(p.id)\n",
                "        base_url = p.get_base_url() if isinstance(p, APIProvider) else getattr(p, \"base_url\", None)\n",
                "        print(f\"{p.id:14} {p.auth_type.value:9} {str(status.configured):>10} \"\n",
                "              f\"{status.source or '-':>8}   {base_url or '(default)'}\")\n",
                "    print()\n",
                "\n",
                "describe(\"text\", registry.text.list())\n",
                "describe(\"image\", registry.image.list())\n",
                "describe(\"audio\", registry.audio.list())\n",
                "describe(\"video\", registry.video.list())"
            ]
        },
