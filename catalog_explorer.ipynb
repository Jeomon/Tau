            "source": [
                "import json, time\n",
                "from collections import Counter\n",
                "from tau.inference.model.catalog import Catalog, default_catalog\n",
                "\n",
                "cat = default_catalog()\n",
                "cat.load()\n",
                "data = cat.data\n",
                "\n",
                "age_h = (time.time() - cat.fetched_at) / 3600 if cat.fetched_at else None\n",
                "n_models = sum(len(p.get(\"models\", {})) for p in data.values())\n",
                "print(f\"cache file : {cat.path}\")\n",
                "print(f\"fetched    : {time.ctime(cat.fetched_at) if cat.fetched_at else 'unknown'}\"\n",
                "      + (f\"  ({age_h:.1f}h ago, stale={cat.is_stale()})\" if age_h is not None else \"\"))\n",
                "print(f\"providers  : {len(data)}\")\n",
                "print(f\"models     : {n_models}\")"
            ]
        },
