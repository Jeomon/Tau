                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "type": "number",
                      "description": "Horizontal position in px from left of mural"
                    },
                    "y": {
                      "type": "number",
                      "description": "Vertical position in px from top of mural"
                    },
                    "text": {
                      "type": "string",
